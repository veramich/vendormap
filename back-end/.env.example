# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Geocoding (defaults to public Nominatim if not set)
NOMINATIM_USER_AGENT=your-app-name
NOMINATIM_URL=https://nominatim.openstreetmap.org
OVERPASS_URL=https://overpass-api.de/api/interpreter

# Cloudflare R2 storage (for photo uploads)
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Firebase Admin SDK — paste the full service account JSON as a single line
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Server
PORT=8000
NODE_ENV=production

# CORS — set to your Cloudflare Pages domain in production
FRONTEND_ORIGIN=https://your-app.pages.dev
